---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Run any agent skill in one command. Make skills easier to try, easier to trust, and easier to adopt with skillx." />
    <meta property="og:title" content={title} />
    <meta property="og:description" content="Run any agent skill in one command. Make skills easier to try, easier to trust, and easier to adopt with skillx." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://skillx.run" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Space+Grotesk:wght@400;500;700&display=swap" rel="stylesheet" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --landing-bg: #f6f2ea;
    --landing-surface: rgba(255, 255, 255, 0.74);
    --landing-surface-strong: #ffffff;
    --landing-text: #111111;
    --landing-muted: rgba(17, 17, 17, 0.68);
    --landing-border: rgba(17, 17, 17, 0.12);
    --landing-border-strong: rgba(17, 17, 17, 0.18);
    --landing-accent: #355cff;
    --landing-accent-soft: rgba(53, 92, 255, 0.12);
    --landing-accent-strong: #243fc2;
    --landing-shadow: 0 24px 80px rgba(17, 17, 17, 0.08);
    --landing-radius-lg: 20px;
    --landing-radius-xl: 28px;
  }

  * {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  html {
    scroll-behavior: smooth;
    background: var(--landing-bg);
  }

  body {
    font-family: 'Space Grotesk', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    background:
      radial-gradient(circle at top left, rgba(53, 92, 255, 0.08), transparent 28%),
      radial-gradient(circle at top right, rgba(255, 184, 108, 0.1), transparent 24%),
      var(--landing-bg);
    color: var(--landing-text);
    line-height: 1.5;
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  h1,
  h2,
  h3,
  h4 {
    font-weight: 700;
    letter-spacing: -0.05em;
    line-height: 1.02;
  }

  code,
  pre,
  .mono {
    font-family: 'JetBrains Mono', 'Fira Code', 'SF Mono', 'Cascadia Code', monospace;
  }

  nav a {
    text-decoration: none;
  }

  .landing-container {
    width: min(1120px, calc(100% - 2rem));
    margin-inline: auto;
  }

  .landing-section {
    padding-block: clamp(3rem, 6vw, 6rem);
  }
</style>
