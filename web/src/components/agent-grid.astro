---
const agents = [
  // Tier 1
  { name: 'Claude Code', type: 'CLI', tier: 1, yolo: '--dangerously-skip-permissions' },
  { name: 'OpenAI Codex', type: 'CLI', tier: 1, yolo: '--full-auto' },
  { name: 'GitHub Copilot', type: 'IDE', tier: 1, yolo: null },
  { name: 'Cursor', type: 'IDE', tier: 1, yolo: null },
  // Tier 2
  { name: 'Gemini CLI', type: 'CLI', tier: 2, yolo: '--sandbox=none' },
  { name: 'OpenCode', type: 'CLI', tier: 2, yolo: null },
  { name: 'Amp', type: 'CLI', tier: 2, yolo: null },
  { name: 'Windsurf', type: 'IDE', tier: 2, yolo: null },
  { name: 'Cline', type: 'IDE', tier: 2, yolo: null },
  { name: 'Roo Code', type: 'IDE', tier: 2, yolo: null },
  // Tier 3
  { name: 'Goose', type: 'CLI', tier: 3, yolo: null },
  { name: 'Kiro', type: 'CLI', tier: 3, yolo: null },
  { name: 'Aider', type: 'CLI', tier: 3, yolo: null },
  { name: 'OpenClaw', type: 'CLI', tier: 3, yolo: null },
  { name: 'Qwen Code', type: 'CLI', tier: 3, yolo: null },
  { name: 'Droid', type: 'CLI', tier: 3, yolo: null },
  { name: 'Warp', type: 'CLI', tier: 3, yolo: null },
  { name: 'OpenHands', type: 'CLI', tier: 3, yolo: null },
  { name: 'Command Code', type: 'CLI', tier: 3, yolo: null },
  { name: 'Mistral Vibe', type: 'CLI', tier: 3, yolo: null },
  { name: 'Qoder', type: 'CLI', tier: 3, yolo: null },
  { name: 'Kode', type: 'CLI', tier: 3, yolo: null },
  { name: 'Kilo Code', type: 'IDE', tier: 3, yolo: null },
  { name: 'Trae', type: 'IDE', tier: 3, yolo: null },
  { name: 'Augment', type: 'IDE', tier: 3, yolo: null },
  { name: 'Continue', type: 'IDE', tier: 3, yolo: null },
  { name: 'CodeBuddy', type: 'IDE', tier: 3, yolo: null },
  { name: 'Antigravity', type: 'IDE', tier: 3, yolo: null },
  { name: 'Zencoder', type: 'IDE', tier: 3, yolo: null },
  { name: 'Junie', type: 'IDE', tier: 3, yolo: null },
  { name: 'Replit Agent', type: 'IDE', tier: 3, yolo: null },
];
---

<section class="agents">
  <div class="container">
    <h2>Works with Every Agent</h2>
    <p class="subtitle">One adapter per agent. 32 built-in + custom agents via config.</p>

    <div class="tier-sections">
      <div class="tier">
        <h3>
          <span class="tier-badge t1">Tier 1</span>
          Full support
        </h3>
        <div class="agent-cards">
          {agents.filter(a => a.tier === 1).map(agent => (
            <div class="agent-card">
              <div class="agent-name">{agent.name}</div>
              <div class="agent-meta">
                <span class={`type-badge ${agent.type.toLowerCase()}`}>{agent.type}</span>
                {agent.yolo && <span class="yolo-badge">YOLO</span>}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="tier">
        <h3>
          <span class="tier-badge t2">Tier 2</span>
          Full support
        </h3>
        <div class="agent-cards">
          {agents.filter(a => a.tier === 2).map(agent => (
            <div class="agent-card">
              <div class="agent-name">{agent.name}</div>
              <div class="agent-meta">
                <span class={`type-badge ${agent.type.toLowerCase()}`}>{agent.type}</span>
                {agent.yolo && <span class="yolo-badge">YOLO</span>}
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="tier">
        <h3>
          <span class="tier-badge t3">Tier 3</span>
          Full support
        </h3>
        <div class="agent-cards">
          {agents.filter(a => a.tier === 3).map(agent => (
            <div class="agent-card">
              <div class="agent-name">{agent.name}</div>
              <div class="agent-meta">
                <span class={`type-badge ${agent.type.toLowerCase()}`}>{agent.type}</span>
              </div>
            </div>
          ))}
          <div class="agent-card more">
            <div class="agent-name">+ custom agents</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .agents {
    padding: 6rem 0;
    border-top: 1px solid #1e293b;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  h2 {
    text-align: center;
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .subtitle {
    text-align: center;
    color: #94a3b8;
    font-size: 1.2rem;
    margin-bottom: 3rem;
  }

  .tier {
    margin-bottom: 2.5rem;
  }

  .tier h3 {
    font-size: 1rem;
    color: #94a3b8;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .tier-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.75rem;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
  }

  .t1 { background: rgba(99, 102, 241, 0.2); color: #a5b4fc; }
  .t2 { background: rgba(34, 211, 238, 0.15); color: #67e8f9; }
  .t3 { background: rgba(148, 163, 184, 0.15); color: #94a3b8; }

  .agent-cards {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 0.75rem;
  }

  .agent-card {
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 8px;
    padding: 1rem;
    transition: border-color 0.15s;
  }

  .agent-card:hover {
    border-color: #334155;
  }

  .agent-card.more {
    display: flex;
    align-items: center;
    justify-content: center;
    border-style: dashed;
  }

  .agent-name {
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 0.5rem;
  }

  .agent-meta {
    display: flex;
    gap: 0.5rem;
  }

  .type-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    text-transform: uppercase;
  }

  .type-badge.cli {
    background: rgba(34, 197, 94, 0.15);
    color: #4ade80;
  }

  .type-badge.ide {
    background: rgba(251, 191, 36, 0.15);
    color: #fbbf24;
  }

  .yolo-badge {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.7rem;
    padding: 0.1rem 0.4rem;
    border-radius: 3px;
    background: rgba(239, 68, 68, 0.15);
    color: #f87171;
  }
</style>
