---
const steps = [
  { icon: '↓', name: 'Fetch', desc: 'Pull from any Git host or skill directory' },
  { icon: '⊘', name: 'Scan', desc: '23 security rules check before use' },
  { icon: '→', name: 'Inject', desc: 'Copy skill files into agent config' },
  { icon: '▶', name: 'Run', desc: 'Launch your agent with the skill' },
  { icon: '✓', name: 'Clean', desc: 'Auto-remove when session ends' },
];
---

<section class="lifecycle">
  <div class="container">
    <h2>How skillx works</h2>
    <div class="pipeline">
      {steps.map((step, i) => (
        <div class="step">
          <div class="node neo-box">
            <span class="icon">{step.icon}</span>
          </div>
          {i < steps.length - 1 && <div class="connector" />}
          <div class="label">
            <span class="name">{step.name}</span>
            <span class="desc">{step.desc}</span>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .lifecycle {
    padding: 6rem 0;
    background: #fffbf2;
    border-top: 3px solid #1a1a1a;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  h2 {
    text-align: center;
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 4rem;
    color: #1a1a1a;
    text-transform: uppercase;
  }

  .pipeline {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    position: relative;
  }

  .step {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex: 1;
    position: relative;
    max-width: 180px;
  }

  .node {
    width: 64px;
    height: 64px;
    border-radius: 4px;
    background: #ffffff;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    z-index: 1;
    transition: transform 0.1s;
  }

  .step:hover .node {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0px #1a1a1a;
    background: #6366f1;
  }
  
  .step:hover .icon {
    color: white;
  }

  .icon {
    font-size: 1.5rem;
    color: #1a1a1a;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 800;
  }

  .connector {
    position: absolute;
    top: 32px;
    left: calc(50% + 32px);
    width: calc(100% - 64px);
    height: 3px;
    background: #1a1a1a;
    z-index: 0;
  }

  .label {
    margin-top: 1.5rem;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .name {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    font-weight: 800;
    color: #1a1a1a;
    text-transform: uppercase;
  }

  .desc {
    font-size: 0.9rem;
    color: #333;
    line-height: 1.5;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .pipeline {
      flex-direction: column;
      align-items: center;
      gap: 2rem;
    }

    .step {
      flex-direction: row;
      align-items: center;
      max-width: none;
      width: 100%;
      gap: 1.5rem;
    }

    .node {
      width: 56px;
      height: 56px;
      flex-shrink: 0;
    }

    .connector {
      display: none;
    }

    .label {
      margin-top: 0;
      text-align: left;
    }
  }
</style>
