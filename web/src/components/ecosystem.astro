---
const tierOneAgents = ['Claude Code', 'Codex', 'Copilot', 'Cursor'];
const tierTwoAgents = [
  'Gemini CLI', 'Windsurf', 'Cline', 'Roo Code',
  'Amp', 'OpenCode', 'Goose', 'Aider',
];
const agentsMore = 20;

const primarySources = ['GitHub', 'GitLab', 'Bitbucket', 'Codeberg'];
const otherSources = [
  'SourceHut', 'Gitea / Forgejo', 'Hugging Face', 'Gist',
  'skills.sh', 'ClawHub', 'LobehHub', 'SkillHub Club',
];
const sourcesMore = 6;
---

<section class="ecosystem">
  <div class="container">
    <h2>The Agent Skill Ecosystem</h2>
    <p class="subtitle">Works with every agent. Pulls from every source.</p>
    <div class="columns">

      <div class="card neo-box">
        <div class="card-header">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2a5 5 0 0 1 5 5v3a5 5 0 0 1-10 0V7a5 5 0 0 1 5-5z"/>
              <path d="M8 14s-1.5 2-1.5 4a5.5 5.5 0 0 0 11 0c0-2-1.5-4-1.5-4"/>
              <path d="M12 18v4"/>
            </svg>
          </div>
          <div>
            <h3>Agents <span class="count">32+</span></h3>
            <p class="card-desc">AI coding assistants, IDEs, and CLI tools</p>
          </div>
        </div>
        <div class="tags">
          {tierOneAgents.map(name => (
            <span class="tag tier-one">{name}</span>
          ))}
          {tierTwoAgents.map(name => (
            <span class="tag">{name}</span>
          ))}
          <span class="tag more">+ {agentsMore} more</span>
          <span class="tag custom">+ custom</span>
        </div>
        <a href="/agents/overview/" class="see-all">See all agents &rarr;</a>
      </div>

      <div class="card neo-box">
        <div class="card-header">
          <div class="card-icon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <polyline points="3.27 6.96 12 12.01 20.73 6.96"/>
              <line x1="12" y1="22.08" x2="12" y2="12"/>
            </svg>
          </div>
          <div>
            <h3>Sources <span class="count">18+</span></h3>
            <p class="card-desc">Git hosts, registries, and skill directories</p>
          </div>
        </div>
        <div class="tags">
          {primarySources.map(name => (
            <span class="tag primary">{name}</span>
          ))}
          {otherSources.map(name => (
            <span class="tag">{name}</span>
          ))}
          <span class="tag more">+ {sourcesMore} more</span>
        </div>
        <a href="/platforms/overview/" class="see-all">See all sources &rarr;</a>
      </div>

    </div>

    <div class="cta-line">
      <span>One CLI. Every agent. Every source.</span>
    </div>
  </div>
</section>

<style>
  .ecosystem {
    padding: 6rem 0;
    background: #fdf6e3;
    border-top: 3px solid #1a1a1a;
  }

  .container {
    max-width: 1000px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  h2 {
    text-align: center;
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 0.5rem;
    color: #1a1a1a;
    text-transform: uppercase;
  }

  .subtitle {
    text-align: center;
    color: #333;
    font-size: 1.25rem;
    margin-bottom: 4rem;
    font-weight: 500;
  }

  .columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }

  /* Card wrapper */
  .card {
    background: #ffffff;
    padding: 2rem;
    transition: transform 0.2s;
  }

  .card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0px #1a1a1a;
  }

  /* Card header with icon */
  .card-header {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .card-icon {
    width: 48px;
    height: 48px;
    border: 2px solid #1a1a1a;
    border-radius: 4px;
    background: #6366f1;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    color: white;
    box-shadow: 3px 3px 0px #1a1a1a;
  }

  .card-header h3 {
    font-size: 1.4rem;
    font-weight: 800;
    margin: 0;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: #1a1a1a;
  }

  .card-desc {
    font-size: 0.9rem;
    color: #333;
    margin: 0.25rem 0 0 0;
    font-weight: 500;
  }

  .count {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.8rem;
    padding: 0.2rem 0.6rem;
    border: 2px solid #1a1a1a;
    background: #ff9f1c;
    color: #000;
    font-weight: 800;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-bottom: 1.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: center;
    padding: 0.4rem 0.8rem;
    background: white;
    border: 2px solid #1a1a1a;
    border-radius: 4px;
    font-size: 0.85rem;
    color: #1a1a1a;
    font-weight: 700;
    white-space: nowrap;
    transition: all 0.1s;
    box-shadow: 2px 2px 0px #1a1a1a;
  }

  .tag:hover {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px #1a1a1a;
    background: #f5f5f5;
  }

  /* Tier 1 agents — indigo accent */
  .tag.tier-one {
    background: #6366f1;
    color: white;
  }

  .tag.tier-one:hover {
    background: #4f46e5;
  }

  /* Primary sources — indigo accent */
  .tag.primary {
    background: #6366f1;
    color: white;
  }

  .tag.primary:hover {
    background: #4f46e5;
  }

  .tag.more {
    color: #666;
    border-style: dashed;
    background: transparent;
    box-shadow: none;
  }
  
  .tag.more:hover {
    transform: none;
    box-shadow: none;
  }

  .tag.custom {
    color: #6366f1;
    border-color: #6366f1;
    border-style: dashed;
    background: transparent;
    box-shadow: none;
  }

  .see-all {
    font-size: 1rem;
    color: #1a1a1a;
    font-weight: 800;
    text-decoration: underline;
    text-underline-offset: 4px;
    transition: color 0.15s;
  }

  .see-all:hover {
    color: #6366f1;
  }

  /* Bottom CTA */
  .cta-line {
    text-align: center;
    margin-top: 4rem;
    font-size: 1.2rem;
    color: #1a1a1a;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cta-line span {
    border-bottom: 4px solid #6366f1;
    padding-bottom: 4px;
  }

  @media (max-width: 768px) {
    .columns {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
    h2 {
      font-size: 2rem;
    }
  }
</style>
