---
---
<nav>
  <div class="nav-inner">
    <a href="/" class="brand">
      <span class="logo">skillx</span>
    </a>
    <div class="nav-links">
      <a href="/getting-started/">Docs</a>
      <a href="/blog">Blog</a>
      <a href="https://github.com/skillx-run/skillx" class="gh-link">
        GitHub
      </a>
    </div>
  </div>
</nav>

<style>
  nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fffbf2;
    border-bottom: 2px solid #1a1a1a;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0.75rem 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .brand {
    text-decoration: none;
  }

  .logo {
    font-family: 'JetBrains Mono', monospace;
    font-weight: 800;
    font-size: 1.5rem;
    color: #1a1a1a;
    text-shadow: 2px 2px 0px #6366f1;
  }

  .nav-links {
    display: flex;
    gap: 1.5rem;
    align-items: center;
  }

  .nav-links a {
    color: #1a1a1a;
    text-decoration: none;
    font-size: 1rem;
    font-weight: 600;
    transition: transform 0.1s;
  }

  .nav-links a:hover {
    color: #6366f1;
    transform: translateY(-1px);
  }

  .gh-link {
    padding: 0.4rem 1rem;
    border: 2px solid #1a1a1a;
    border-radius: 4px;
    background: white;
    box-shadow: 3px 3px 0px #1a1a1a;
    font-size: 0.9rem !important;
  }

  .gh-link:hover {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0px #1a1a1a;
    background: #f5f5f5;
  }
</style>
