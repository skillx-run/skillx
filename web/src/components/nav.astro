---
---
<nav class="site-nav" aria-label="Primary">
  <div class="nav-inner">
    <a href="/" class="brand" aria-label="skillx home">
      <span class="brand-mark">skillx</span>
    </a>
    <div class="nav-links">
      <a href="/getting-started/">Docs</a>
      <a href="/blog/">Blog</a>
      <a href="https://github.com/skillx-run/skillx" class="gh-link">
        GitHub
      </a>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: rgba(246, 242, 234, 0.78);
    backdrop-filter: blur(18px);
    border-bottom: 1px solid var(--landing-border, rgba(17, 17, 17, 0.12));
  }

  .nav-inner {
    width: min(1120px, calc(100% - 2rem));
    margin-inline: auto;
    min-height: 4.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--landing-border, rgba(17, 17, 17, 0.12));
    border-radius: 999px;
    background: var(--landing-surface, rgba(255, 255, 255, 0.74));
    box-shadow: var(--landing-shadow, 0 24px 80px rgba(17, 17, 17, 0.08));
    text-decoration: none;
  }

  .brand-mark {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    font-weight: 700;
    letter-spacing: -0.05em;
    color: var(--landing-text, #111111);
  }

  .nav-links {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .nav-links a {
    display: inline-flex;
    align-items: center;
    padding: 0.65rem 0.95rem;
    border-radius: 999px;
    border: 1px solid transparent;
    color: var(--landing-muted, rgba(17, 17, 17, 0.68));
    font-size: 0.95rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      color 0.18s ease,
      border-color 0.18s ease,
      background-color 0.18s ease,
      transform 0.18s ease;
  }

  .nav-links a:hover {
    color: var(--landing-text, #111111);
    border-color: var(--landing-border, rgba(17, 17, 17, 0.12));
    background: var(--landing-surface, rgba(255, 255, 255, 0.74));
    transform: translateY(-1px);
  }

  @media (max-width: 480px) {
    .nav-inner {
      width: min(1120px, calc(100% - 1rem));
      gap: 0.55rem;
      min-height: 4rem;
    }

    .brand {
      padding: 0.55rem 0.8rem;
    }

    .brand-mark {
      font-size: 0.94rem;
    }

    .nav-links {
      gap: 0.2rem;
    }

    .nav-links a {
      padding: 0.45rem 0.55rem;
      font-size: 0.88rem;
    }
  }
</style>
