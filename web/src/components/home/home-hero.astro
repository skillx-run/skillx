---
const terminalRows = [
  { label: 'resolve skill source', value: 'github:skillx-run/skillx/examples/skills/code-review' },
  { label: 'scan before inject', value: '30 rules | 5 risk levels | PASS' },
  { label: 'inject temporarily', value: 'session-only workspace mount' },
  { label: 'launch agent', value: 'claude-code / codex / cursor' },
  { label: 'cleanup on exit', value: 'workspace restored' },
];
---

<section data-home-section="hero" class="landing-section hero-section">
  <div class="landing-container hero-grid">
    <div class="hero-copy">
      <p class="eyebrow">npx for agent skills</p>
      <h1>Run any agent skill in one command.</h1>
      <p class="lede">Make skills easier to try, easier to trust, and easier to adopt.</p>
      <p class="supporting">
        Scan before inject. Load only what is needed. Clean up automatically when the session ends.
      </p>

      <div class="hero-actions">
        <a class="button button-primary" href="/getting-started/installation/">Install skillx</a>
        <a class="button button-secondary" href="/getting-started/">See how it works</a>
      </div>

      <div class="trust-block">
        <p class="trust-label">Built to make adoption easier without lowering trust.</p>
        <div class="trust-strip" aria-label="Homepage trust strip">
          <span>32+ agents</span>
          <span>18+ sources</span>
          <span>30 rules</span>
          <span>5 risk levels</span>
        </div>
      </div>
    </div>

    <div class="terminal-card" aria-label="Terminal replay">
      <div class="terminal-chrome">
        <span></span>
        <span></span>
        <span></span>
        <span>skillx session</span>
      </div>

      <div class="terminal-body">
        <div class="terminal-line terminal-line-command">
          <span class="prompt">$</span>
          <span>skillx run github:skillx-run/skillx/examples/skills/code-review "Review my auth module"</span>
        </div>

        {terminalRows.map((row) => (
          <div class="terminal-line">
            <span class="terminal-label">{row.label}</span>
            <span class="terminal-value">{row.value}</span>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    padding-top: clamp(2rem, 4vw, 4rem);
    padding-bottom: clamp(4rem, 7vw, 7rem);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }

  .hero-copy {
    max-width: 36rem;
  }

  .eyebrow {
    margin-bottom: 1rem;
    color: var(--landing-accent-strong);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 5.8rem);
    line-height: 0.94;
    max-width: 11ch;
  }

  .lede {
    margin-top: 1.2rem;
    font-size: clamp(1.1rem, 2vw, 1.35rem);
    color: var(--landing-text);
    max-width: 32ch;
  }

  .supporting {
    margin-top: 0.9rem;
    max-width: 36ch;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.7rem;
  }

  .button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0.85rem 1.15rem;
    border-radius: 999px;
    border: 1px solid var(--landing-border);
    text-decoration: none;
    font-weight: 700;
    transition:
      transform 0.18s ease,
      border-color 0.18s ease,
      background-color 0.18s ease,
      box-shadow 0.18s ease;
  }

  .button:hover {
    transform: translateY(-1px);
  }

  .button-primary {
    background: var(--landing-text);
    color: #ffffff;
    box-shadow: 0 16px 36px rgba(17, 17, 17, 0.16);
  }

  .button-primary:hover {
    background: var(--landing-accent-strong);
  }

  .button-secondary {
    background: var(--landing-surface);
    color: var(--landing-text);
  }

  .button-secondary:hover {
    background: var(--landing-surface-strong);
    border-color: var(--landing-border-strong);
  }

  .trust-block {
    margin-top: 1.5rem;
  }

  .trust-label {
    margin-bottom: 0.8rem;
    font-size: 0.92rem;
    color: var(--landing-muted);
  }

  .trust-strip {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .trust-strip span {
    display: inline-flex;
    align-items: center;
    min-height: 2.35rem;
    padding: 0.45rem 0.8rem;
    border-radius: 999px;
    border: 1px solid var(--landing-border);
    background: var(--landing-surface);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.86rem;
    font-weight: 600;
    color: var(--landing-text);
  }

  .terminal-card {
    border: 1px solid var(--landing-border);
    border-radius: var(--landing-radius-xl);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(250, 247, 240, 0.94));
    box-shadow: var(--landing-shadow);
    overflow: hidden;
  }

  .terminal-chrome {
    display: grid;
    grid-template-columns: repeat(3, 0.8rem) 1fr;
    gap: 0.5rem;
    align-items: center;
    padding: 0.95rem 1rem;
    border-bottom: 1px solid var(--landing-border);
    background: rgba(255, 255, 255, 0.75);
    color: var(--landing-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
  }

  .terminal-chrome span:nth-child(-n + 3) {
    width: 0.72rem;
    height: 0.72rem;
    border-radius: 999px;
    background: rgba(17, 17, 17, 0.18);
  }

  .terminal-chrome span:last-child {
    justify-self: end;
    font-weight: 700;
    color: var(--landing-text);
  }

  .terminal-body {
    display: grid;
    gap: 0.7rem;
    padding: 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.92rem;
  }

  .terminal-line {
    display: grid;
    grid-template-columns: minmax(8.5rem, 11rem) minmax(0, 1fr);
    gap: 0.75rem;
    align-items: start;
  }

  .terminal-line-command {
    grid-template-columns: auto minmax(0, 1fr);
    padding-bottom: 0.4rem;
    margin-bottom: 0.2rem;
    border-bottom: 1px dashed var(--landing-border);
  }

  .prompt {
    color: var(--landing-accent-strong);
    font-weight: 700;
  }

  .terminal-label {
    color: var(--landing-muted);
    text-transform: lowercase;
  }

  .terminal-value {
    color: var(--landing-text);
    font-weight: 600;
  }

  @media (max-width: 920px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy {
      max-width: 42rem;
    }
  }

  @media (max-width: 640px) {
    .hero-section {
      padding-top: 1.5rem;
    }

    h1 {
      max-width: 100%;
      font-size: clamp(2.7rem, 13vw, 4rem);
    }

    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .button {
      width: 100%;
    }

    .trust-strip {
      gap: 0.5rem;
    }

    .trust-strip span {
      width: 100%;
      justify-content: center;
    }

    .terminal-line {
      grid-template-columns: 1fr;
      gap: 0.25rem;
    }

    .terminal-line-command {
      grid-template-columns: auto minmax(0, 1fr);
    }
  }
</style>
