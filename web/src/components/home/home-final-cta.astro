---
const installCommand = 'curl -fsSL https://skillx.run/install.sh | sh';
---

<section data-home-section="final-cta" class="landing-section final-cta-section">
  <div class="landing-container final-cta-shell">
    <div class="final-cta-copy">
      <p class="eyebrow">Try it now</p>
      <h2>Run your first skill in under a minute.</h2>
      <p class="lede">
        Make skills easier to try and easier to adopt. Install skillx, run one command, and
        keep the setup temporary.
      </p>
    </div>

    <div class="install-panel">
      <p class="command-label">Install command</p>
      <button class="install-bar copy-command" type="button" data-command={installCommand}>
        <code>{installCommand}</code>
        <span class="copy-label">Copy</span>
      </button>
      <div class="action-row">
        <a href="/getting-started/installation/" class="neo-btn">Install skillx</a>
        <a href="https://github.com/skillx-run/skillx" class="neo-btn neo-btn-secondary">
          View on GitHub
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .final-cta-section {
    padding-top: 0;
  }

  .final-cta-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(0, 0.95fr);
    gap: 1.5rem;
    align-items: center;
  }

  .final-cta-copy {
    max-width: 33rem;
  }

  .eyebrow {
    margin-bottom: 0.9rem;
    color: var(--landing-accent-strong);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    max-width: 12ch;
  }

  .lede {
    margin-top: 1rem;
    max-width: 34ch;
    color: var(--landing-muted);
    font-size: 1.06rem;
  }

  .install-panel {
    padding: 1.4rem;
    border: 1px solid var(--landing-border);
    border-radius: var(--landing-radius-lg);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(250, 247, 240, 0.98));
    box-shadow: var(--landing-shadow);
  }

  .command-label {
    margin-bottom: 0.8rem;
    color: var(--landing-accent-strong);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .install-bar {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    width: 100%;
    padding: 1rem 1.1rem;
    border: 1px solid var(--landing-border-strong);
    border-radius: 16px;
    background: #fff;
    text-align: left;
    cursor: pointer;
    appearance: none;
    font: inherit;
    color: inherit;
  }

  .install-bar code {
    flex: 1;
    color: var(--landing-text);
    font-size: 0.98rem;
    line-height: 1.5;
    word-break: break-all;
  }

  .copy-label {
    flex-shrink: 0;
    padding: 0.35rem 0.65rem;
    border-radius: 999px;
    background: var(--landing-accent-soft);
    color: var(--landing-accent-strong);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.74rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .action-row {
    display: flex;
    gap: 0.9rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  @media (max-width: 900px) {
    .final-cta-shell {
      grid-template-columns: 1fr;
    }

    .final-cta-copy {
      max-width: none;
    }
  }

  @media (max-width: 640px) {
    .install-bar {
      padding: 0.9rem 1rem;
      align-items: flex-start;
      flex-direction: column;
    }

    .copy-label {
      align-self: flex-start;
    }
  }
</style>

<script>
  const buttons = document.querySelectorAll('.copy-command');

  buttons.forEach((button) => {
    button.addEventListener('click', async () => {
      const command = button.getAttribute('data-command') || '';

      try {
        await navigator.clipboard.writeText(command);
        button.dataset.copied = 'true';
        const label = button.querySelector('.copy-label');
        if (label) label.textContent = 'Copied';
        window.setTimeout(() => {
          delete button.dataset.copied;
          if (label) label.textContent = 'Copy';
        }, 1400);
      } catch {
        window.prompt('Copy this command', command);
      }
    });
  });
</script>
