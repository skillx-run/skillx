---
import { buildSkillxRunCommand, famousSkills } from '../../data/famous-skills.mjs';

const cases = famousSkills.slice(0, 3).map((skill) => ({
  title: skill.homepageTitle,
  body: skill.homepageBody,
  command: buildSkillxRunCommand(skill, skill.homepagePrompt),
  note: skill.homepageNote,
  href: skill.runUrl,
  docsHref: skill.docsHref,
}));
---

<section data-home-section="use-cases" class="landing-section use-cases-section">
  <div class="landing-container use-cases-shell">
    <div class="use-cases-copy">
      <p class="eyebrow">Use cases</p>
      <h2>Start with a real skill, not a toy example.</h2>
      <p class="lede">Pick a public Agent Skill and use it for one useful job right away.</p>
    </div>

    <div class="use-cases-grid">
      {cases.map((item) => (
        <article class="case-card">
          <h3>{item.title}</h3>
          <p class="case-body">{item.body}</p>
          <button class="case-command copy-command" type="button" data-command={item.command}>
            <code>{item.command}</code>
            <span class="copy-label">Copy</span>
          </button>
          <p class="case-note">{item.note}</p>
          <div class="case-actions">
            <a href={item.docsHref}>See docs</a>
            <a href={item.href} class="case-link-secondary">View source</a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .use-cases-section {
    padding-top: 0;
  }

  .use-cases-shell {
    display: grid;
    gap: 1.4rem;
  }

  .use-cases-copy {
    max-width: 38rem;
  }

  .eyebrow {
    margin-bottom: 0.9rem;
    color: var(--landing-accent-strong);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    max-width: 15ch;
  }

  .lede {
    margin-top: 1rem;
    max-width: 36ch;
    color: var(--landing-muted);
    font-size: 1.06rem;
  }

  .use-cases-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .case-card {
    display: grid;
    gap: 0.9rem;
    padding: 1.35rem;
    border: 1px solid var(--landing-border);
    border-radius: var(--landing-radius-lg);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(250, 247, 240, 0.96));
    box-shadow: var(--landing-shadow);
  }

  .case-card h3 {
    font-size: 1.4rem;
  }

  .case-body,
  .case-note {
    color: var(--landing-muted);
  }

  .case-command {
    display: flex;
    align-items: flex-start;
    gap: 0.8rem;
    width: 100%;
    padding: 0.95rem;
    border: 1px solid var(--landing-border);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.78);
    text-align: left;
    cursor: pointer;
    appearance: none;
    font: inherit;
    color: inherit;
    transition:
      border-color 0.18s ease,
      background-color 0.18s ease;
  }

  .case-command:hover {
    border-color: var(--landing-border-strong);
    background: var(--landing-surface-strong);
  }

  .case-command code {
    flex: 1;
    font-size: 0.84rem;
    line-height: 1.55;
    word-break: break-word;
  }

  .copy-label {
    flex-shrink: 0;
    padding: 0.3rem 0.55rem;
    border-radius: 999px;
    background: var(--landing-accent-soft);
    color: var(--landing-accent-strong);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .case-note {
    font-size: 0.95rem;
  }

  .case-actions a {
    display: inline-flex;
    align-items: center;
    min-height: 2.6rem;
    padding: 0.7rem 0.95rem;
    border-radius: 999px;
    border: 1px solid var(--landing-border);
    background: var(--landing-surface);
    color: var(--landing-text);
    font-weight: 700;
    text-decoration: none;
  }

  .case-actions {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .case-actions a:hover {
    border-color: var(--landing-border-strong);
    background: var(--landing-surface-strong);
  }

  .case-actions .case-link-secondary {
    background: transparent;
  }

  @media (max-width: 1080px) {
    .use-cases-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
