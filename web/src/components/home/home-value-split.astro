---
const valueCards = [
  {
    eyebrow: 'Too much friction',
    title: 'Manual setup',
    summary: 'Too much friction before the first result.',
    bullets: [
      'Find the right repo and hope you picked the right folder',
      'Figure out where your agent expects the skill to live',
      'Inspect the files yourself before you trust them',
      'Clean everything up manually when the session is over',
    ],
  },
  {
    eyebrow: 'One-command first run',
    title: 'Run with skillx',
    summary: 'From public GitHub URL to first run in one command.',
    bullets: [
      'Paste the GitHub skill URL',
      'Scan before inject',
      'Run it in your agent for one session',
      'Clean up automatically on exit',
    ],
  },
];
---

<section data-home-section="value-split" class="landing-section value-split-section">
  <div class="landing-container value-split-grid">
    <div class="value-split-copy">
      <p class="eyebrow">Why skillx</p>
      <h2>Trying a GitHub skill should not feel like setup work.</h2>
      <p class="lede">
        The hard part is not finding a skill. The hard part is getting from a public GitHub
        URL to a safe first run without manual setup, trust guesswork, or cleanup.
      </p>
    </div>

    <div class="value-split-cards" aria-label="Value split cards">
      {valueCards.map((card) => (
        <article class="value-card">
          <p class="card-eyebrow">{card.eyebrow}</p>
          <h3>{card.title}</h3>
          <p class="card-summary">{card.summary}</p>
          <ul class="card-list">
            {card.bullets.map((bullet) => (
              <li>{bullet}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .value-split-section {
    padding-top: 0;
  }

  .value-split-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  .value-split-copy {
    position: sticky;
    top: 1.5rem;
    max-width: 31rem;
  }

  .eyebrow {
    margin-bottom: 0.9rem;
    color: var(--landing-accent-strong);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    max-width: 13ch;
  }

  .lede {
    margin-top: 1rem;
    max-width: 35ch;
    color: var(--landing-muted);
    font-size: 1.06rem;
  }

  .value-split-cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .value-card {
    padding: 1.4rem 1.35rem 1.45rem;
    border: 1px solid var(--landing-border);
    border-radius: var(--landing-radius-lg);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(250, 247, 240, 0.96));
    box-shadow: var(--landing-shadow);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .value-card:hover {
    transform: translateY(-2px);
    border-color: var(--landing-border-strong);
  }

  .card-eyebrow {
    display: inline-flex;
    margin-bottom: 0.85rem;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    background: var(--landing-accent-soft);
    color: var(--landing-accent-strong);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .value-card h3 {
    font-size: 1.45rem;
    margin-bottom: 0.55rem;
  }

  .card-summary {
    color: var(--landing-text);
    font-weight: 600;
  }

  .card-list {
    margin-top: 0.9rem;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.65rem;
    color: var(--landing-muted);
  }

  .card-list li::marker {
    color: var(--landing-accent-strong);
  }

  @media (max-width: 900px) {
    .value-split-grid {
      grid-template-columns: 1fr;
    }

    .value-split-copy {
      position: static;
      max-width: none;
    }
  }

  @media (max-width: 720px) {
    .value-split-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
