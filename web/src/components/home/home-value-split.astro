---
const leftSteps = [
  'Install the skill onto your machine',
  'Link it into your agent\'s folder',
  'Audit the files yourself — nothing scans before injection',
  'Uninstall it when you\'re done',
];

const rightSteps = ['Paste the skill URL.'];
---

<section data-home-section="value-split" class="landing-section value-split-section">
  <div class="landing-container value-split-grid">
    <div class="value-split-copy">
      <p class="eyebrow">Install vs. run</p>
      <h2>Most skill managers install. skillx runs.</h2>
      <p class="lede">
        Tools like <code>skills</code> and <code>skillfish</code> drop files into your agent
        and leave them there. skillx fetches, scans, runs once, and cleans up.
      </p>
    </div>

    <div class="value-split-cards" aria-label="Install versus run comparison">
      <article class="value-card value-card-install">
        <p class="card-eyebrow">Install it into your agent</p>
        <p class="card-subtitle">Tools like <code>skills</code>, <code>skillfish</code>, …</p>
        <ol class="card-list">
          {leftSteps.map((step) => (
            <li>{step}</li>
          ))}
        </ol>
        <p class="card-footer card-footer-muted">4 steps per skill</p>
      </article>

      <article class="value-card value-card-run">
        <p class="card-eyebrow">skillx run</p>
        <p class="card-subtitle">One command.</p>
        <ol class="card-list">
          {rightSteps.map((step) => (
            <li>{step}</li>
          ))}
        </ol>
        <p class="card-aux">skillx does the rest: scan → inject → run → clean.</p>
        <p class="card-footer card-footer-accent">1 command</p>
      </article>
    </div>
  </div>
</section>

<style>
  .value-split-section {
    padding-top: 0;
  }

  .value-split-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: start;
  }

  .value-split-copy {
    position: sticky;
    top: 1.5rem;
    max-width: 32rem;
  }

  .eyebrow {
    margin-bottom: 0.9rem;
    color: var(--landing-accent-strong);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h2 {
    font-size: clamp(2.2rem, 4vw, 3.5rem);
    max-width: 14ch;
  }

  .lede {
    margin-top: 1rem;
    max-width: 36ch;
    color: var(--landing-muted);
    font-size: 1.06rem;
  }

  .lede code {
    padding: 0.1rem 0.3rem;
    border-radius: 6px;
    background: rgba(17, 17, 17, 0.06);
    color: var(--landing-text);
    font-size: 0.92em;
  }

  .value-split-cards {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .value-card {
    display: flex;
    flex-direction: column;
    padding: 1.4rem 1.35rem 1.45rem;
    border: 1px solid var(--landing-border);
    border-radius: var(--landing-radius-lg);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(250, 247, 240, 0.96));
    box-shadow: var(--landing-shadow);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease;
  }

  .value-card:hover {
    transform: translateY(-2px);
    border-color: var(--landing-border-strong);
  }

  .value-card-run {
    border-color: var(--landing-border-strong);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(244, 246, 255, 0.9));
  }

  .card-eyebrow {
    display: inline-flex;
    align-self: flex-start;
    margin-bottom: 0.55rem;
    padding: 0.3rem 0.6rem;
    border-radius: 999px;
    background: var(--landing-accent-soft);
    color: var(--landing-accent-strong);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.76rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .card-subtitle {
    margin-bottom: 0.9rem;
    color: var(--landing-muted);
    font-size: 0.95rem;
  }

  .card-subtitle code {
    padding: 0.05rem 0.3rem;
    border-radius: 6px;
    background: rgba(17, 17, 17, 0.06);
    color: var(--landing-text);
    font-size: 0.92em;
  }

  .card-list {
    margin: 0;
    padding-left: 1.25rem;
    display: grid;
    gap: 0.55rem;
    color: var(--landing-text);
  }

  .card-list li {
    line-height: 1.5;
  }

  .card-list li::marker {
    color: var(--landing-accent-strong);
    font-weight: 700;
  }

  .card-aux {
    margin-top: 0.9rem;
    padding: 0.7rem 0.9rem;
    border-radius: 12px;
    background: rgba(53, 92, 255, 0.08);
    color: var(--landing-muted);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    line-height: 1.45;
  }

  .card-footer {
    margin-top: auto;
    padding-top: 0.95rem;
    border-top: 1px dashed var(--landing-border);
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .value-card .card-footer {
    margin-top: 1.1rem;
  }

  .card-footer-muted {
    color: var(--landing-muted);
  }

  .card-footer-accent {
    color: var(--landing-accent-strong);
  }

  @media (max-width: 900px) {
    .value-split-grid {
      grid-template-columns: 1fr;
    }

    .value-split-copy {
      position: static;
      max-width: none;
    }
  }

  @media (max-width: 720px) {
    .value-split-cards {
      grid-template-columns: 1fr;
    }
  }
</style>
