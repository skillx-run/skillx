---
---
<section class="cta">
  <div class="container">
    <h2>Ready to run your first skill?</h2>
    <div class="install-bar neo-box">
      <code>curl -fsSL https://skillx.run/install.sh | sh</code>
      <button class="copy-btn" data-text="curl -fsSL https://skillx.run/install.sh | sh" aria-label="Copy">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <rect x="9" y="9" width="13" height="13" rx="1" ry="1"></rect>
          <path d="M5 15H4a1 1 0 01-1-1V4a1 1 0 011-1h9a1 1 0 011 1v1"></path>
        </svg>
      </button>
    </div>
    <div class="cta-group">
      <a href="/getting-started/" class="neo-btn">Get Started</a>
      <a href="https://github.com/skillx-run/skillx" class="neo-btn neo-btn-secondary">Star on GitHub</a>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.cta .copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-text') || '';
      await navigator.clipboard.writeText(text);
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 1500);
    });
  });
</script>

<style>
  .cta {
    padding: 8rem 0;
    text-align: center;
    position: relative;
    background: #fffbf2;
    border-top: 3px solid #1a1a1a;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    z-index: 1;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 2.5rem;
    color: #1a1a1a;
    text-transform: uppercase;
  }

  .install-bar {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: #ffffff;
    padding: 1rem 1.5rem;
    margin-bottom: 3rem;
    width: 100%;
    max-width: 600px;
  }

  .install-bar code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    color: #1a1a1a;
    font-weight: 600;
    word-break: break-all;
    text-align: left;
  }

  .copy-btn {
    background: #f0f0f0;
    border: 2px solid #1a1a1a;
    color: #1a1a1a;
    cursor: pointer;
    padding: 6px;
    border-radius: 4px;
    transition: all 0.1s;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    box-shadow: 2px 2px 0px #1a1a1a;
  }

  .copy-btn:hover {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px #1a1a1a;
  }

  .copy-btn.copied {
    background: #22c55e;
    color: white;
  }

  .cta-group {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    h2 {
      font-size: 2rem;
    }
    .install-bar code {
      font-size: 0.8rem;
    }
  }
</style>
