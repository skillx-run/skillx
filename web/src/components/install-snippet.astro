---
---
<section class="install">
  <div class="container">
    <h2>Install in seconds</h2>
    <div class="snippets">
      <div class="snippet">
        <div class="snippet-header">
          <span class="label">Cargo</span>
        </div>
        <div class="snippet-body">
          <code>cargo install skillx</code>
          <button class="copy-btn" data-text="cargo install skillx" aria-label="Copy">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
            </svg>
          </button>
        </div>
      </div>
      <div class="snippet">
        <div class="snippet-header">
          <span class="label">Homebrew</span>
        </div>
        <div class="snippet-body">
          <code>brew install skillx</code>
          <button class="copy-btn" data-text="brew install skillx" aria-label="Copy">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"></path>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  document.querySelectorAll('.copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-text') || '';
      await navigator.clipboard.writeText(text);
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 1500);
    });
  });
</script>

<style>
  .install {
    padding: 4rem 0;
  }

  .container {
    max-width: 700px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  h2 {
    text-align: center;
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 2rem;
    color: #94a3b8;
  }

  .snippets {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .snippet {
    background: #0f172a;
    border: 1px solid #1e293b;
    border-radius: 8px;
    overflow: hidden;
  }

  .snippet-header {
    padding: 0.5rem 1rem;
    border-bottom: 1px solid #1e293b;
  }

  .label {
    font-size: 0.75rem;
    color: #64748b;
    font-family: 'JetBrains Mono', monospace;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .snippet-body {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.75rem 1rem;
  }

  code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    color: #a5b4fc;
  }

  .copy-btn {
    background: none;
    border: none;
    color: #64748b;
    cursor: pointer;
    padding: 4px;
    border-radius: 4px;
    transition: color 0.15s;
  }

  .copy-btn:hover {
    color: #e2e8f0;
  }

  .copy-btn.copied {
    color: #22c55e;
  }

  @media (max-width: 600px) {
    .snippets {
      grid-template-columns: 1fr;
    }
  }
</style>
