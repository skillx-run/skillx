---
---
<section class="hero">
  <div class="container">
    <div class="badge">v0.4</div>
    <p class="pain">Agent skills are powerful. And untrusted.</p>
    <h1>
      Run any agent skill. <span class="accent">Safely.</span> <br/>Without installing it.
    </h1>
    <p class="tagline">
      One command &mdash; fetch, scan, run, auto-clean.
    </p>

    <div class="terminal-wrapper">
      <div class="terminal">
        <div class="terminal-header">
          <div class="dots">
            <span class="dot red"></span>
            <span class="dot yellow"></span>
            <span class="dot green"></span>
          </div>
          <span class="terminal-title">terminal — skillx run</span>
        </div>
        <div class="terminal-body">
          <div class="line">
            <span class="prompt">$</span>
            <span class="cmd typing">skillx run github:skillx-run/skillx.run/examples/skills/name-poem "Your Name"</span>
          </div>
          <div class="line output delay-1">
            <span class="cyan">→</span> Resolving source...
          </div>
          <div class="line output delay-2">
            <span class="green">✓</span> Resolved: name-poem
          </div>
          <div class="line output delay-3">
            <span class="cyan">→</span> Scanning for security issues...
          </div>
          <div class="line output delay-4">
            <span class="green">✓</span> Scan Result: <span class="pass-badge">PASS</span> <span class="dim">(23 rules checked)</span>
          </div>
          <div class="line output delay-5">
            <span class="green">✓</span> Using agent: Claude Code
          </div>
          <div class="line output delay-6">
            <span class="green">✓</span> Injected 1 files to .claude/skills/name-poem
          </div>
          <div class="line output delay-7">
            <span class="cyan">→</span> Launching agent...
          </div>
          <div class="line output delay-8">
            <span class="dim">  [Claude Code running...]</span>
          </div>
          <div class="line output delay-9">
            <span class="green">✓</span> Agent completed.
          </div>
          <div class="line output delay-10">
            <span class="green">✓</span> Cleanup done.
          </div>
        </div>
      </div>
    </div>

    <div class="cta-group">
      <a href="/getting-started/" class="neo-btn">Get Started</a>
      <a href="https://github.com/skillx-run/skillx" class="neo-btn neo-btn-secondary">View on GitHub</a>
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 8rem 0 6rem;
    text-align: center;
    position: relative;
    background: #fffbf2;
  }

  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: #ff9f1c;
    color: #000;
    border: 2px solid #000;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85rem;
    font-weight: 700;
    margin-bottom: 2rem;
    box-shadow: 2px 2px 0px #000;
  }

  .pain {
    color: #666;
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  h1 {
    font-size: 4rem;
    font-weight: 900;
    line-height: 1.1;
    margin-bottom: 1.5rem;
    color: #1a1a1a;
  }

  .accent {
    color: #6366f1;
    text-decoration: underline;
    text-decoration-thickness: 4px;
    text-underline-offset: 4px;
  }

  .tagline {
    font-size: 1.25rem;
    color: #333;
    line-height: 1.6;
    margin-bottom: 4rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
    font-weight: 500;
  }

  /* Neobrutalist Terminal */
  .terminal-wrapper {
    position: relative;
    max-width: 760px;
    margin: 0 auto 4rem;
  }

  .terminal {
    background: #ffffff;
    border: 3px solid #1a1a1a;
    border-radius: 4px;
    overflow: hidden;
    box-shadow: 8px 8px 0px #1a1a1a;
    text-align: left;
  }

  .terminal-header {
    display: flex;
    align-items: center;
    padding: 0.75rem 1rem;
    background: #f0f0f0;
    border-bottom: 3px solid #1a1a1a;
    gap: 0.75rem;
  }

  .dots {
    display: flex;
    gap: 8px;
  }

  .dot {
    width: 14px;
    height: 14px;
    border-radius: 50%;
    border: 2px solid #1a1a1a;
  }

  .dot.red { background: #ff5f56; }
  .dot.yellow { background: #ffbd2e; }
  .dot.green { background: #27c93f; }

  .terminal-title {
    color: #1a1a1a;
    font-size: 0.9rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
  }

  .terminal-body {
    padding: 1.5rem;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9rem;
    line-height: 1.7;
    color: #1a1a1a;
  }

  .line {
    white-space: pre-wrap;
    display: flex;
    align-items: baseline;
    margin-bottom: 0.25rem;
  }

  .prompt {
    color: #6366f1;
    margin-right: 0.75rem;
    font-weight: 800;
  }

  .cmd {
    font-weight: 600;
  }

  .output {
    opacity: 0;
    animation: fadeIn 0.2s ease forwards;
  }

  .cyan { color: #0891b2; font-weight: 700; }
  .green { color: #16a34a; font-weight: 700; }
  .dim { color: #666; }
  
  .pass-badge {
    background: #22c55e;
    color: white;
    padding: 0 0.4rem;
    font-weight: 800;
    border: 2px solid #1a1a1a;
    font-size: 0.8rem;
  }

  .delay-1 { animation-delay: 0.6s; }
  .delay-2 { animation-delay: 1.0s; }
  .delay-3 { animation-delay: 1.4s; }
  .delay-4 { animation-delay: 2.0s; }
  .delay-5 { animation-delay: 2.6s; }
  .delay-6 { animation-delay: 3.2s; }
  .delay-7 { animation-delay: 3.8s; }
  .delay-8 { animation-delay: 4.4s; }
  .delay-9 { animation-delay: 5.5s; }
  .delay-10 { animation-delay: 6.0s; }

  .typing {
    overflow: hidden;
    border-right: 3px solid #6366f1;
    white-space: nowrap;
    animation:
      typing 1.2s steps(70) forwards,
      blink 0.8s step-end infinite;
    width: 0;
  }

  @keyframes typing {
    to { width: 100%; }
  }

  @keyframes blink {
    50% { border-color: transparent; }
  }

  @keyframes fadeIn {
    to { opacity: 1; }
  }

  /* CTA */
  .cta-group {
    display: flex;
    gap: 1.5rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* Use global neo-btn classes defined in custom.css */

  @media (max-width: 768px) {
    h1 {
      font-size: 2.5rem;
    }
    .hero {
      padding: 5rem 0 4rem;
    }
    .terminal-body {
      font-size: 0.75rem;
    }
    .terminal-title {
      display: none;
    }
  }
</style>
