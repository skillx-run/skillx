---
const methods = [
  { label: 'Shell', cmd: 'curl -fsSL https://skillx.run/install.sh | sh', default: true },
  { label: 'Homebrew', cmd: 'brew install skillx-run/tap/skillx', default: false },
  { label: 'Cargo', cmd: 'cargo install skillx', default: false },
];
---
<section class="install">
  <div class="container">
    <h2>Try skillx in seconds</h2>
    <div class="tabs" role="tablist">
      {methods.map((m, i) => (
        <button
          class={`tab ${m.default ? 'active' : ''}`}
          role="tab"
          data-index={i}
          aria-selected={m.default ? 'true' : 'false'}
        >
          {m.label}
        </button>
      ))}
    </div>
    <div class="install-panels">
      {methods.map((m, i) => (
        <div class={`install-panel ${m.default ? 'active' : ''}`} data-index={i}>
          <div class="install-bar neo-box">
            <code>{m.cmd}</code>
            <button class="copy-btn" data-text={m.cmd} aria-label="Copy">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                <rect x="9" y="9" width="13" height="13" rx="1" ry="1"></rect>
                <path d="M5 15H4a1 1 0 01-1-1V4a1 1 0 011-1h9a1 1 0 011 1v1"></path>
              </svg>
            </button>
          </div>
        </div>
      ))}
    </div>
    <a href="/getting-started/installation/" class="install-more">More install options &rarr;</a>
  </div>
</section>

<script>
  document.querySelectorAll('.install .tab').forEach(tab => {
    tab.addEventListener('click', () => {
      const index = (tab as HTMLElement).dataset.index;
      const section = tab.closest('.install');
      section?.querySelectorAll('.tab').forEach(t => {
        t.classList.remove('active');
        t.setAttribute('aria-selected', 'false');
      });
      tab.classList.add('active');
      tab.setAttribute('aria-selected', 'true');
      section?.querySelectorAll('.install-panel').forEach(p => {
        p.classList.toggle('active', (p as HTMLElement).dataset.index === index);
      });
    });
  });

  document.querySelectorAll('.install .copy-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const text = btn.getAttribute('data-text') || '';
      await navigator.clipboard.writeText(text);
      btn.classList.add('copied');
      setTimeout(() => btn.classList.remove('copied'), 1500);
    });
  });
</script>

<style>
  .install {
    padding: 6rem 0;
    text-align: center;
    background: #fffbf2;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 0 2rem;
  }

  h2 {
    font-size: 2.5rem;
    font-weight: 900;
    margin-bottom: 2.5rem;
    color: #1a1a1a;
    text-transform: uppercase;
  }

  .tabs {
    display: inline-flex;
    gap: 0.5rem;
    background: #fffbf2;
    padding: 4px;
    margin-bottom: 2rem;
  }

  .tab {
    padding: 0.5rem 1.5rem;
    background: white;
    border: 2px solid #1a1a1a;
    color: #1a1a1a;
    font-size: 1rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.1s;
    box-shadow: 3px 3px 0px #1a1a1a;
  }

  .tab:hover {
    transform: translate(1px, 1px);
    box-shadow: 2px 2px 0px #1a1a1a;
  }

  .tab.active {
    background: #6366f1;
    color: white;
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0px #1a1a1a;
  }

  .install-panels {
    margin-bottom: 2rem;
  }

  .install-panel {
    display: none;
  }

  .install-panel.active {
    display: block;
  }

  .install-bar {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    background: #ffffff;
    padding: 1rem 1.5rem;
    width: 100%;
    max-width: 600px;
  }

  .install-bar code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 1rem;
    color: #1a1a1a;
    font-weight: 600;
    word-break: break-all;
    text-align: left;
  }

  .copy-btn {
    background: #f0f0f0;
    border: 2px solid #1a1a1a;
    color: #1a1a1a;
    cursor: pointer;
    padding: 6px;
    border-radius: 4px;
    transition: all 0.1s;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    box-shadow: 2px 2px 0px #1a1a1a;
  }

  .copy-btn:hover {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0px #1a1a1a;
  }

  .copy-btn.copied {
    background: #22c55e;
    color: white;
  }

  .install-more {
    display: block;
    color: #1a1a1a;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    transition: color 0.15s;
  }

  .install-more:hover {
    color: #6366f1;
  }

  @media (max-width: 768px) {
    h2 {
      font-size: 2rem;
    }
    .install-bar code {
      font-size: 0.8rem;
    }
    .tabs {
      flex-direction: column;
      width: 100%;
    }
  }
</style>
