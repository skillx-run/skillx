---
import Base from '../../layouts/base.astro';
import Nav from '../../components/nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Blog — skillx">
  <Nav />
  <main>
    <div class="container">
      <header class="blog-header">
        <h1>Blog</h1>
        <p class="subtitle">Latest news and updates from the skillx team.</p>
      </header>
      <div class="posts">
        {posts.map((post) => (
          <article class="post-card neo-box">
            <a href={`/blog/${post.id}`}>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h2>{post.data.title}</h2>
              <p class="description">{post.data.description}</p>
              <span class="read-more">Read more &rarr;</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </main>
</Base>

<style>
  main {
    background: #fffbf2;
    color: #1a1a1a;
    min-height: 100vh;
    padding-bottom: 6rem;
  }

  .container {
    max-width: 800px;
    margin: 0 auto;
    padding: 6rem 2rem;
  }

  .blog-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  h1 {
    font-size: 3.5rem;
    font-weight: 900;
    margin-bottom: 1rem;
    text-transform: uppercase;
    color: #1a1a1a;
  }

  .subtitle {
    font-size: 1.25rem;
    color: #333;
    font-weight: 500;
  }

  .posts {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .post-card {
    background: white;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .post-card:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0px #1a1a1a;
  }

  .post-card a {
    display: block;
    padding: 2.5rem;
    text-decoration: none;
    color: inherit;
  }

  time {
    display: inline-block;
    color: #1a1a1a;
    font-size: 0.85rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    background: #ff9f1c;
    padding: 0.2rem 0.6rem;
    border: 2px solid #1a1a1a;
    margin-bottom: 1.5rem;
    box-shadow: 2px 2px 0px #1a1a1a;
  }

  .post-card h2 {
    font-size: 1.8rem;
    font-weight: 900;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .description {
    color: #333;
    margin-bottom: 1.5rem;
    line-height: 1.6;
    font-size: 1.1rem;
    font-weight: 500;
  }

  .read-more {
    font-weight: 800;
    color: #6366f1;
    text-decoration: underline;
    text-underline-offset: 4px;
    text-decoration-thickness: 2px;
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2.5rem;
    }
    .post-card a {
      padding: 1.5rem;
    }
  }
</style>
