---
import Base from '../../layouts/base.astro';
import Nav from '../../components/nav.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base
  title="Blog — skillx"
  description="Latest news and updates from the skillx team."
>
  <Nav />
  <main>
    <div class="container">
      <header class="blog-header">
        <p class="eyebrow">From the team</p>
        <h1>Blog</h1>
        <p class="subtitle">Latest news and updates from the skillx team.</p>
      </header>
      <div class="posts">
        {posts.map((post) => (
          <article class="post-card">
            <a href={`/blog/${post.id}`}>
              <time datetime={post.data.date.toISOString()}>
                {post.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              <h2>{post.data.title}</h2>
              <p class="description">{post.data.description}</p>
              <span class="read-more">Read more &rarr;</span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </main>
</Base>

<style>
  main {
    background:
      radial-gradient(circle at top left, rgba(53, 92, 255, 0.08), transparent 28%),
      radial-gradient(circle at top right, rgba(255, 184, 108, 0.1), transparent 24%),
      #f6f2ea;
    color: #111111;
    min-height: 100vh;
    padding-bottom: 6rem;
  }

  .container {
    width: min(880px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 5.5rem 0 0;
  }

  .blog-header {
    margin-bottom: 2.5rem;
    max-width: 36rem;
  }

  .eyebrow {
    margin-bottom: 0.85rem;
    color: #243fc2;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.82rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  h1 {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.05em;
    line-height: 0.94;
    color: #111111;
  }

  .subtitle {
    max-width: 34ch;
    font-size: 1.15rem;
    color: rgba(17, 17, 17, 0.68);
  }

  .posts {
    display: grid;
    gap: 1.25rem;
  }

  .post-card {
    border: 1px solid rgba(17, 17, 17, 0.12);
    border-radius: 24px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(250, 247, 240, 0.96));
    box-shadow: 0 24px 80px rgba(17, 17, 17, 0.08);
    transition:
      transform 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease;
  }

  .post-card:hover {
    transform: translateY(-2px);
    border-color: rgba(17, 17, 17, 0.18);
    box-shadow: 0 18px 32px rgba(17, 17, 17, 0.14);
  }

  .post-card a {
    display: block;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
  }

  time {
    display: inline-block;
    color: #243fc2;
    font-size: 0.82rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: rgba(53, 92, 255, 0.12);
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    margin-bottom: 1.1rem;
  }

  .post-card h2 {
    font-size: clamp(1.7rem, 3.5vw, 2.3rem);
    font-weight: 700;
    margin-bottom: 0.85rem;
    line-height: 1.04;
    letter-spacing: -0.05em;
  }

  .description {
    color: rgba(17, 17, 17, 0.68);
    margin-bottom: 1.35rem;
    line-height: 1.6;
    font-size: 1.02rem;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-weight: 700;
    color: #243fc2;
    text-decoration: underline;
    text-underline-offset: 0.24em;
    text-decoration-thickness: 0.08em;
  }

  @media (max-width: 768px) {
    .post-card a {
      padding: 1.5rem;
    }
  }
</style>
