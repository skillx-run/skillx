---
import Base from '../../layouts/base.astro';
import Nav from '../../components/nav.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base
  title={`${post.data.title} — skillx`}
  description={post.data.description}
>
  <Nav />
  <main>
    <article class="container">
      <header class="post-header">
        <time datetime={post.data.date.toISOString()}>
          {post.data.date.toLocaleDateString('en-US', {
            year: 'numeric',
            month: 'long',
            day: 'numeric',
          })}
        </time>
        <h1>{post.data.title}</h1>
        {post.data.author && <p class="author">By {post.data.author}</p>}
      </header>
      <div class="content">
        <Content />
      </div>
      <footer class="post-footer">
        <a href="/blog" class="back-link">&larr; Back to blog</a>
      </footer>
    </article>
  </main>
</Base>

<style>
  main {
    background:
      radial-gradient(circle at top left, rgba(53, 92, 255, 0.08), transparent 28%),
      radial-gradient(circle at top right, rgba(255, 184, 108, 0.1), transparent 24%),
      #f6f2ea;
    color: #111111;
    min-height: 100vh;
    padding-bottom: 6rem;
  }

  .container {
    width: min(860px, calc(100% - 2rem));
    margin: 0 auto;
    padding: 5.5rem 0 0;
  }

  .post-header {
    margin-bottom: 2rem;
    max-width: 40rem;
  }

  time {
    display: inline-block;
    color: #243fc2;
    font-size: 0.82rem;
    font-family: 'JetBrains Mono', monospace;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    background: rgba(53, 92, 255, 0.12);
    padding: 0.38rem 0.7rem;
    border-radius: 999px;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: clamp(2.8rem, 8vw, 4.8rem);
    font-weight: 700;
    margin: 0.5rem 0;
    line-height: 0.96;
    letter-spacing: -0.05em;
  }

  .author {
    color: rgba(17, 17, 17, 0.68);
    margin-top: 0.9rem;
    font-size: 1rem;
  }

  .content {
    border: 1px solid rgba(17, 17, 17, 0.12);
    border-radius: 28px;
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(250, 247, 240, 0.96));
    box-shadow: 0 24px 80px rgba(17, 17, 17, 0.08);
    padding: 3rem;
    line-height: 1.75;
    font-size: 1.08rem;
  }

  .content :global(h2) {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 700;
    margin-top: 3rem;
    margin-bottom: 1rem;
    line-height: 1.02;
    letter-spacing: -0.05em;
    color: #111111;
  }

  .content :global(h3) {
    font-size: 1.45rem;
    font-weight: 700;
    margin-top: 2.2rem;
    margin-bottom: 0.9rem;
    letter-spacing: -0.04em;
    color: #111111;
  }

  .content :global(p) {
    margin-bottom: 1.5rem;
    color: rgba(17, 17, 17, 0.76);
  }

  .content :global(pre) {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.94), rgba(250, 247, 240, 0.98));
    border: 1px solid rgba(17, 17, 17, 0.12);
    border-radius: 20px;
    padding: 1.25rem 1.35rem;
    overflow-x: auto;
    margin-bottom: 2rem;
    box-shadow: 0 24px 80px rgba(17, 17, 17, 0.08);
  }

  .content :global(code) {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
    background: rgba(17, 17, 17, 0.05);
    padding: 0.18em 0.38em;
    border-radius: 8px;
    border: 1px solid rgba(17, 17, 17, 0.1);
  }

  .content :global(pre code) {
    background: transparent;
    padding: 0;
    border: none;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
    color: rgba(17, 17, 17, 0.76);
  }

  .content :global(li) {
    margin-bottom: 0.75rem;
  }

  .content :global(strong) {
    font-weight: 800;
  }

  .content :global(blockquote) {
    border: 1px solid rgba(53, 92, 255, 0.16);
    border-radius: 20px;
    padding: 1.25rem 1.4rem;
    background: rgba(53, 92, 255, 0.06);
    margin: 2rem 0;
    color: rgba(17, 17, 17, 0.76);
  }

  .post-footer {
    margin-top: 2rem;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    color: #111111;
    text-decoration: none;
    font-weight: 700;
    border: 1px solid rgba(17, 17, 17, 0.12);
    border-radius: 999px;
    padding: 0.75rem 1.1rem;
    background: rgba(255, 255, 255, 0.74);
    transition:
      transform 0.18s ease,
      background-color 0.18s ease,
      border-color 0.18s ease;
  }

  .back-link:hover {
    transform: translateY(-1px);
    background: #ffffff;
    border-color: rgba(17, 17, 17, 0.18);
  }

  @media (max-width: 768px) {
    .content {
      padding: 1.5rem;
    }
  }
</style>
